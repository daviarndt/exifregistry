{
  "name": "exifregistry",
  "version": "1.4.0",
  "description": "A friendly command-line toolkit for photographers to inspect and edit photo/video metadata (EXIF, GPS, dates).",
  "keywords": [
    "exif",
    "metadata",
    "photography",
    "gps",
    "exiftool",
    "cli"
  ],
  "homepage": "https://exifregistry.com",
  "bugs": "https://github.com/daviarndt/exifregistry/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daviarndt/exifregistry.git"
  },
  "license": "MIT",
  "author": "Davi Arndt",
  "type": "module",
  "bin": {
    "exifreg": "dist/bin.js",
    "exifregistry": "dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "exiftool-vendored": "^30.0.0",
    "opentype.js": "^1.3.4",
    "picocolors": "^1.1.0",
    "sharp": "^0.35.3",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/opentype.js": "^1.3.10",
    "@types/tz-lookup": "^6.1.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.18"
  }
}
